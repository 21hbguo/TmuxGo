<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
<key>Label</key>
<string>com.tmuxgo.gateway</string>
<key>ProgramArguments</key>
<array>
<string>/bin/bash</string>
<string>-c</string>
<string>cd "__TMUXGO_ROOT__" &amp;&amp; exec "__TMUXGO_NPM__" run --workspace=gateway start</string>
</array>
<key>WorkingDirectory</key>
<string>__TMUXGO_ROOT__</string>
<key>EnvironmentVariables</key>
<dict>
<key>NODE_ENV</key>
<string>production</string>
<key>PORT</key>
<string>3001</string>
<key>PATH</key>
<string>__TMUXGO_PATH__</string>
</dict>
<key>RunAtLoad</key>
<true/>
<key>KeepAlive</key>
<true/>
<key>StandardOutPath</key>
<string>__TMUXGO_LOG_DIR__/gateway.log</string>
<key>StandardErrorPath</key>
<string>__TMUXGO_LOG_DIR__/gateway.log</string>
</dict>
</plist>
