[Unit]
Description=TmuxGo Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__TMUXGO_ROOT__
ExecStart=/usr/bin/env npm run --workspace=gateway start
Restart=always
RestartSec=3
KillMode=control-group
Environment=NODE_ENV=production
Environment=PORT=3001

[Install]
WantedBy=tmuxgo.target
